{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>matt-riley/renovate-config",
    "github>matt-riley/renovate-config:node",
    "github>matt-riley/renovate-config:docker",
    "github>matt-riley/renovate-config:github-actions"
  ],
  "packageRules": [
    {
      "description": "Group Elysia framework packages",
      "groupName": "Elysia",
      "matchPackageNames": ["/^elysia/", "/^@elysiajs\\//"],
      "labels": ["elysia", "dependencies"]
    },
    {
      "description": "Group Drizzle ORM packages",
      "groupName": "Drizzle",
      "matchPackageNames": ["/^drizzle/"],
      "labels": ["database", "dependencies"]
    }
  ]
}

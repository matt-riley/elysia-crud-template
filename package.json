{
  "name": "elysia-crud-template",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun src/index.ts",
    "migrate": "bun src/db/migrate.ts",
    "start:migrate": "bun run migrate && bun run start",
    "test": "bun test",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "prepare": "husky"
  },
  "dependencies": {
    "@elysiajs/cors": "1.4.2",
    "@elysiajs/swagger": "1.3.1",
    "drizzle-orm": "0.45.2",
    "elysia": "1.4.29",
    "pg": "8.22.0",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "oxlint": "1.70.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint --fix",
      "prettier -w"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier -w"
    ]
  }
}
